rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /inventory/{itemId} {
      allow read, write: if request.auth != null;
    }
    match /cassettes/{cassetteId} {
      allow read, write: if request.auth != null;
    }
    match /profiles/{profileId} {
      allow read, write: if request.auth != null;
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}